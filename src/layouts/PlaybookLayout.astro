      transition: background 0.15s;
    }
    .nav-popup-item:hover { background: var(--bg-elevated); }
    .nav-popup-icon {
      width: 34px; height: 34px;
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .nav-popup-title {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.15rem;
    }
    .nav-popup-desc {
      font-size: 0.73rem;
      color: var(--text-muted);
      line-height: 1.4;
    }
  </style>

  <script>
    function initBackToTop() {
      const backToTop = document.getElementById('backToTop');
      if (!backToTop) return;

      function scrollToTop(e: Event) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Show/hide on scroll
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          backToTop.classList.add('visible');
        } else {
          backToTop.classList.remove('visible');
        }
      }, { passive: true });

      // Click handler
      backToTop.addEventListener('click', scrollToTop);

      // Touch handler for mobile (faster response)
      backToTop.addEventListener('touchstart', scrollToTop, { passive: false });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBackToTop);
    } else {
      initBackToTop();
    }

    // Register Service Worker for offline support
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }

    // ---- Global Nav: scroll class ----
    const globalNav = document.getElementById('globalNav');
    if (globalNav) {
      window.addEventListener('scroll', () => {
        globalNav.classList.toggle('scrolled', window.scrollY > 20);
      }, { passive: true });
    }

    // ====== About Modal ======
    const aboutBtn = document.getElementById('navAboutBtn');
    const aboutOverlay = document.getElementById('aboutModalOverlay');
    const aboutClose = document.getElementById('aboutModalClose');
    function openAbout() { closeAll(); aboutOverlay?.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeAbout() { aboutOverlay?.classList.remove('open'); document.body.style.overflow = ''; }
    aboutBtn?.addEventListener('click', openAbout);
    aboutClose?.addEventListener('click', closeAbout);
    aboutOverlay?.addEventListener('click', (e: MouseEvent) => { if (e.target === aboutOverlay) closeAbout(); });

    // ====== Curriculum Drawer ======
    const cdrawerOverlay = document.getElementById('cdrawerOverlay');
    const cdrawer = document.getElementById('cdrawer');
    const cdrawerClose = document.getElementById('cdrawerClose');
    const curriculumBtn = document.getElementById('navCurriculumBtn');

    function openCdrawer() {
      closeAll();
      cdrawerOverlay?.classList.add('open');
      cdrawer?.classList.add('open');
      document.body.style.overflow = 'hidden';
      curriculumBtn?.classList.add('open');
    }
    function closeCdrawer() {
      cdrawerOverlay?.classList.remove('open');
      cdrawer?.classList.remove('open');
      document.body.style.overflow = '';
      curriculumBtn?.classList.remove('open');
    }
    curriculumBtn?.addEventListener('click', (e: Event) => {
      e.stopPropagation();
      cdrawer?.classList.contains('open') ? closeCdrawer() : openCdrawer();
    });
    cdrawerClose?.addEventListener('click', closeCdrawer);
    cdrawerOverlay?.addEventListener('click', closeCdrawer);

    // ====== Nav Popups (generic) ======
    function positionPopup(popup: HTMLElement, triggerBtn: HTMLElement) {
      const rect = triggerBtn.getBoundingClientRect();
      const pw = popup.offsetWidth || 300;
      let left = rect.left;
      if (left + pw > window.innerWidth - 12) left = window.innerWidth - pw - 12;
      if (left < 8) left = 8;
      popup.style.left = left + 'px';
    }

    function openPopup(popupId: string, btnId: string) {
      closeAll();
      const popup = document.getElementById(popupId) as HTMLElement | null;
      const btn = document.getElementById(btnId) as HTMLElement | null;
      if (!popup || !btn) return;
      popup.classList.add('open');
      btn.classList.add('open');
      positionPopup(popup, btn);
    }

    function closePopup(popupId: string, btnId: string) {
      document.getElementById(popupId)?.classList.remove('open');
      document.getElementById(btnId)?.classList.remove('open');
    }

    function closeAll() {
      closeCdrawer();
      closeAbout();
      closePopup('deepDivesPopup', 'navDeepDivesBtn');
      closePopup('workshopsPopup', 'navWorkshopsBtn');
    }

    document.getElementById('navDeepDivesBtn')?.addEventListener('click', (e: Event) => {
      e.stopPropagation();
      const popup = document.getElementById('deepDivesPopup');
      popup?.classList.contains('open') ? closePopup('deepDivesPopup','navDeepDivesBtn') : openPopup('deepDivesPopup','navDeepDivesBtn');
    });

    document.getElementById('navWorkshopsBtn')?.addEventListener('click', (e: Event) => {
      e.stopPropagation();
      const popup = document.getElementById('workshopsPopup');
      popup?.classList.contains('open') ? closePopup('workshopsPopup','navWorkshopsBtn') : openPopup('workshopsPopup','navWorkshopsBtn');
    });

    // Close all on outside click
    document.addEventListener('click', (e: MouseEvent) => {
      const t = e.target as HTMLElement;
      if (!t.closest('.nav-popup') && !t.closest('.nav-dropdown-btn') &&
          !t.closest('.cdrawer') && !t.closest('#navAboutBtn')) {
        closeAll();
      }
    });

    // Escape closes everything
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeAll();
    });

    // ====== PWA Install ======
    let deferredInstallPrompt: any = null;
    const navInstallBtn = document.getElementById('navInstallBtn') as HTMLButtonElement | null;
    if (localStorage.getItem('pwa-installed') === 'true' && navInstallBtn) navInstallBtn.style.display = 'none';
    window.addEventListener('beforeinstallprompt', (e: Event) => {
      e.preventDefault();
      deferredInstallPrompt = e;
      if (localStorage.getItem('pwa-installed') !== 'true' && navInstallBtn) navInstallBtn.style.display = 'flex';
    });
    window.addEventListener('appinstalled', () => {
      deferredInstallPrompt = null;
      if (navInstallBtn) navInstallBtn.style.display = 'none';
      localStorage.setItem('pwa-installed', 'true');
    });
    navInstallBtn?.addEventListener('click', async () => {
      if (!deferredInstallPrompt) { alert('Open browser menu → "Add to Home Screen" or "Install app".'); return; }
      deferredInstallPrompt.prompt();
      const { outcome } = await deferredInstallPrompt.userChoice;
      if (outcome === 'accepted') { deferredInstallPrompt = null; navInstallBtn.style.display = 'none'; localStorage.setItem('pwa-installed', 'true'); }
    });

    // ====== Search ======
    document.getElementById('globalSearchBtn')?.addEventListener('click', () => {
      const pf = document.querySelector('[data-pagefind-ui]') as HTMLElement;
      if (pf) { const i = pf.querySelector('input') as HTMLInputElement; if (i) { i.focus(); i.click(); } }
      document.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', ctrlKey: true, bubbles: true }));
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        const pf = document.querySelector('[data-pagefind-ui]') as HTMLElement;
        if (pf) { const i = pf.querySelector('input') as HTMLInputElement; if (i) i.focus(); }
      }
    });
  </script>
</body>
</html>
