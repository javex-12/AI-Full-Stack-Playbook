---
// CommandPalette.astro — Lazy-loaded Pagefind search with Cmd+K
---

<div class="search-overlay" id="searchOverlay">
  <div class="search-modal" role="dialog" aria-label="Search playbook">
    <div class="search-input-wrapper">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input type="search" id="searchInput" class="search-input" placeholder="Search the playbook..." autocomplete="off" aria-label="Search" />
      <kbd class="search-kbd">ESC</kbd>
    </div>
    <div class="search-status" id="searchStatus" aria-live="polite"></div>
    <div class="search-results" id="searchResults" role="listbox"></div>
    <div class="search-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
      <span><kbd>↵</kbd> Open</span>
      <span><kbd>ESC</kbd> Close</span>
    </div>
  </div>
</div>

<style is:global>
  .search-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    display: flex; align-items: flex-start; justify-content: center;
    padding-top: 15vh;
    opacity: 0; visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }
  .search-overlay.open { opacity: 1; visibility: visible; }

  .search-modal {
    width: 100%; max-width: 580px;
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 12px; overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.5);
    transform: translateY(-10px) scale(0.98);
    transition: transform 0.2s var(--ease-out);
  }
  .search-overlay.open .search-modal { transform: translateY(0) scale(1); }

  .search-input-wrapper {
    display: flex; align-items: center; padding: 0 1rem;
    border-bottom: 1px solid var(--border-subtle);
  }
  .search-icon { color: var(--text-faint); flex-shrink: 0; }
  .search-input {
    flex: 1; background: none; border: none;
    padding: 1rem; font-size: 1rem;
    font-family: var(--font-sans); color: var(--text-primary); outline: none;
  }
  .search-input::placeholder { color: var(--text-faint); }
  .search-input::-webkit-search-cancel-button { -webkit-appearance: none; }
  .search-kbd {
    font-family: var(--font-mono); font-size: 0.65rem;
    background: var(--bg-base); border: 1px solid var(--border-default);
    padding: 0.2rem 0.4rem; border-radius: 4px; color: var(--text-faint);
  }

  .search-status {
    padding: 0.4rem 1rem; font-size: 0.75rem; color: var(--text-faint);
    font-family: var(--font-mono); display: none;
  }
  .search-status.visible { display: block; }

  .search-results { max-height: 360px; overflow-y: auto; }
  .search-results:empty { display: none; }

  :global(.search-result) {
    display: block; padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--border-subtle);
    cursor: pointer; transition: background 0.1s; text-decoration: none;
  }
  :global(.search-result:hover), :global(.search-result.active) { background: var(--bg-hover); }
  :global(.search-result-title) { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.15rem; }
  :global(.search-result-section) {
    font-family: var(--font-mono); font-size: 0.65rem; color: var(--brand-accent);
    text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;
  }
  :global(.search-result-excerpt) {
    font-size: 0.8rem; color: var(--text-muted); line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  :global(.search-result-excerpt mark) {
    background: var(--brand-accent-dim); color: var(--brand-accent);
    padding: 0 0.15rem; border-radius: 2px;
  }
  :global(.search-no-results) { padding: 2rem 1rem; text-align: center; color: var(--text-faint); font-size: 0.9rem; }

  .search-footer {
    display: flex; gap: 1.5rem; padding: 0.6rem 1rem;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.7rem; color: var(--text-faint);
  }
  .search-footer kbd {
    font-family: var(--font-mono); font-size: 0.6rem;
    background: var(--bg-base); border: 1px solid var(--border-default);
    padding: 0.1rem 0.3rem; border-radius: 3px; margin-right: 0.2rem;
  }

  @media (max-width: 640px) {
    .search-overlay { padding: 0; align-items: flex-end; }
    .search-modal { max-width: 100%; border-radius: 12px 12px 0 0; max-height: 85vh; }
    .search-footer { display: none; }
  }
</style>

<script>
  let pagefind: any = null;
  let activeIndex = -1;
  let currentResults: HTMLElement[] = [];
  let pagefindLoaded = false;
  let pagefindFailed = false;

  function debounce(fn: Function, ms: number) {
    let timer: ReturnType<typeof setTimeout>;
    return (...args: any[]) => { clearTimeout(timer); timer = setTimeout(() => fn(...args), ms); };
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div'); div.textContent = str; return div.innerHTML;
  }

  function initSearch() {
    const overlay = document.getElementById('searchOverlay');
    const input = document.getElementById('searchInput') as HTMLInputElement;
    const resultsContainer = document.getElementById('searchResults');
    const status = document.getElementById('searchStatus');

    if (!overlay || !input || !resultsContainer || !status) return;

    async function loadPagefind() {
      if (pagefindLoaded || pagefindFailed) return;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.init();
        pagefindLoaded = true;
      } catch (err) {
        pagefindFailed = true;
        status.innerHTML = 'Search index not built. Run <code style="background:var(--bg-elevated);padding:0.1rem 0.3rem;border-radius:3px;font-size:0.7rem;">pnpm build</code> to enable search.';
        status.classList.add('visible');
      }
    }

    const executeSearch = debounce(async (query: string) => {
      if (!query) {
        resultsContainer.innerHTML = '';
        status.classList.remove('visible');
        currentResults = [];
        activeIndex = -1;
        return;
      }

      if (!pagefind) {
        if (pagefindFailed) {
          status.innerHTML = 'Search not available. Run <code style="background:var(--bg-elevated);padding:0.1rem 0.3rem;border-radius:3px;font-size:0.7rem;">pnpm build</code> first.';
          status.classList.add('visible');
        }
        resultsContainer.innerHTML = '';
        currentResults = [];
        activeIndex = -1;
        return;
      }

      status.textContent = 'Searching...';
      status.classList.add('visible');
      const searchInstance = await pagefind.search(query);
      const count = searchInstance.results.length;
      status.textContent = count > 0 ? `${count} result${count !== 1 ? 's' : ''}` : 'No results found';
      resultsContainer.innerHTML = '';
      currentResults = [];
      activeIndex = -1;
      if (count === 0) {
        resultsContainer.innerHTML = `<div class="search-no-results">No results for "<strong>${escapeHtml(query)}</strong>"</div>`;
        return;
      }
      for (const item of searchInstance.results.slice(0, 8)) {
        const data = await item.data();
        const el = document.createElement('a');
        el.className = 'search-result';
        el.href = data.url;
        el.setAttribute('role', 'option');
        const section = data.meta?.section || '';
        el.innerHTML = `${section ? `<div class="search-result-section">${escapeHtml(section)}</div>` : ''}<div class="search-result-title">${escapeHtml(data.meta?.title || 'Untitled')}</div><div class="search-result-excerpt">${data.excerpt}</div>`;
        resultsContainer.appendChild(el);
        currentResults.push(el);
      }
    }, 200);

    function updateActive() {
      currentResults.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
      if (activeIndex >= 0 && currentResults[activeIndex]) currentResults[activeIndex].scrollIntoView({ block: 'nearest' });
    }

    function openSearch() {
      overlay.classList.add('open');
      input.focus();
      input.value = '';
      resultsContainer.innerHTML = '';
      status.classList.remove('visible');
      activeIndex = -1;
      document.body.style.overflow = 'hidden';
    }

    function closeSearch() {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
      input.blur();
    }

    // Expose for external triggers
    (window as any).openPlaybookSearch = openSearch;

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        overlay.classList.contains('open') ? closeSearch() : openSearch();
      }
      if (e.key === 'Escape' && overlay.classList.contains('open')) closeSearch();
    });

    // Click outside to close
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeSearch(); });

    // Listen for custom open-search event (from search trigger button)
    document.addEventListener('open-search', () => openSearch());

    // Search input handlers
    input.addEventListener('input', () => executeSearch(input.value.trim()));
    input.addEventListener('focus', () => loadPagefind(), { once: true });

    input.addEventListener('keydown', (e) => {
      if (!currentResults.length) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, currentResults.length - 1); updateActive(); }
      if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, -1); updateActive(); }
      if (e.key === 'Enter' && activeIndex >= 0) { e.preventDefault(); const link = currentResults[activeIndex].getAttribute('href'); if (link) window.location.href = link; }
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
</script>
