---
interface Props {
  code: string;
  language?: string;
  filename?: string;
  showLineNumbers?: boolean;
}

const { code, language = 'text', filename, showLineNumbers = false } = Astro.props;
const lines = code.trim().split('\n');
---

<div class="code-block">
  <div class="code-header">
    <div class="code-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    {filename && <span class="code-filename">{filename}</span>}
    {language !== 'text' && <span class="code-lang">{language}</span>}
  </div>
  <pre class="code-pre"><code class={`language-${language}`}>
    {showLineNumbers ? (
      lines.map((line, i) => (
        <span class="code-line">
          <span class="line-number">{i + 1}</span>
          <span class="line-content">{line}</span>
        </span>
      ))
    ) : (
      code.trim()
    )}
  </code></pre>
</div>

<style>
  .code-block {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 10px;
    overflow: hidden;
    margin: 1.5rem 0;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-subtle);
  }

  .code-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .code-lang {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: auto;
  }

  .code-pre {
    margin: 0;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    background: none;
    border: none;
    border-radius: 0;
    font-size: 0.82rem;
    line-height: 1.7;
    white-space: pre;
  }

  .code-pre code {
    font-family: var(--font-mono);
    color: var(--text-secondary);
    background: none;
    border: none;
    padding: 0;
  }

  .code-line {
    display: block;
  }

  .line-number {
    display: inline-block;
    width: 2rem;
    text-align: right;
    padding-right: 1rem;
    color: var(--text-faint);
    user-select: none;
    opacity: 0.5;
  }

  .line-content {
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .code-pre {
      padding: 0.75rem 1rem;
      font-size: 0.75rem;
    }
  }
</style>
