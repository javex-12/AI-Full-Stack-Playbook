---
// LoadingScreen.astro — Premium animated loading overlay
---

<div class="ls" id="loadingScreen">
  <!-- Interactive Neural Grid Background -->
  <canvas class="ls-canvas" id="lsCanvas"></canvas>

  <!-- Glowing Radial Background Element -->
  <div class="ls-glow-sphere"></div>

  <div class="ls-content">
    <!-- Visual Ring Hub -->
    <div class="ls-hub">
      <!-- Pulsing Outer Hexagon/Radar border -->
      <div class="ls-radar-ping"></div>
      
      <!-- Logo Ring -->
      <div class="ls-logo-ring">
        <svg viewBox="0 0 100 100" class="ls-ring-svg">
          <circle cx="50" cy="50" r="44" class="ls-ring-track"/>
          <circle cx="50" cy="50" r="44" class="ls-ring-spin"/>
          <circle cx="50" cy="50" r="38" class="ls-ring-spin-inner"/>
        </svg>
        <!-- Inner Core Bolt Icon -->
        <div class="ls-logo-inner">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#3ad29f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Cyberpunk Diagnostic Layout -->
    <div class="ls-info-panel">
      <!-- Brand -->
      <div class="ls-brand">
        <span class="ls-brand-main">CYDERCODER</span><span class="ls-brand-dot"> // PLAYBOOK</span>
      </div>
      
      <!-- Tech HUD Readouts -->
      <div class="ls-hud-row">
        <span class="ls-hud-tag">SYS.STATUS: OK</span>
        <span class="ls-hud-tag" id="lsHudPct">00%</span>
      </div>

      <!-- Progress Track -->
      <div class="ls-bar-wrap">
        <div class="ls-bar" id="lsBar"></div>
      </div>

      <!-- Diagnostic Console output -->
      <div class="ls-console">
        <span class="ls-console-prompt">></span>
        <span class="ls-status" id="lsStatus">INITIALIZING...</span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .ls {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #040706;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), visibility 0.8s;
  }
  .ls.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Core Ambient Glow Sphere */
  .ls-glow-sphere {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(58,210,159,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
    filter: blur(40px);
  }

  /* Interactive Canvas Grid */
  .ls-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.45;
    z-index: 0;
  }

  /* Content Container styling */
  .ls-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    width: 320px;
  }

  /* ── Visual Radar Hub ── */
  .ls-hub {
    position: relative;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ls-radar-ping {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(58,210,159,0.15);
    border-radius: 50%;
    animation: lsRadar 2.4s cubic-bezier(0.16,1,0.3,1) infinite;
  }
  @keyframes lsRadar {
    0%   { transform: scale(0.7); opacity: 1; }
    100% { transform: scale(1.4); opacity: 0; }
  }

  .ls-logo-ring {
    position: relative;
    width: 96px;
    height: 96px;
  }
  .ls-ring-svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .ls-ring-track {
    fill: none;
    stroke: rgba(58,210,159,0.04);
    stroke-width: 2;
  }
  .ls-ring-spin {
    fill: none;
    stroke: url(#lsGrad);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 276;
    stroke-dashoffset: 276;
    animation: lsSpin 2s cubic-bezier(0.4,0,0.2,1) infinite;
  }
  .ls-ring-spin-inner {
    fill: none;
    stroke: #3ad29f;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-dasharray: 238;
    stroke-dashoffset: 238;
    opacity: 0.45;
    transform-origin: center;
    animation: lsSpinInner 3s linear infinite;
  }

  @keyframes lsSpin {
    0%   { stroke-dashoffset: 276; transform: rotate(0deg); }
    50%  { stroke-dashoffset: 69; }
    100% { stroke-dashoffset: 276; transform: rotate(360deg); }
  }
  @keyframes lsSpinInner {
    0%   { stroke-dashoffset: 238; transform: rotate(360deg); }
    50%  { stroke-dashoffset: 119; }
    100% { stroke-dashoffset: 238; transform: rotate(0deg); }
  }

  .ls-logo-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 0 10px rgba(58,210,159,0.6));
    animation: lsPulse 1.8s ease-in-out infinite;
  }
  @keyframes lsPulse {
    0%,100% { transform: scale(0.96); opacity: 0.85; }
    50%     { transform: scale(1.06); opacity: 1; }
  }

  /* ── Cyber HUD Display ── */
  .ls-info-panel {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .ls-brand {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: #e2ece9;
    text-align: center;
    margin-bottom: 0.4rem;
  }
  .ls-brand-main {
    background: linear-gradient(135deg, #e2ece9 30%, #7fffda 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .ls-brand-dot {
    color: #3ad29f;
    font-size: 0.9rem;
    font-weight: 400;
  }

  .ls-hud-row {
    display: flex;
    justify-content: space-between;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    margin-bottom: -0.2rem;
  }
  .ls-hud-tag {
    text-transform: uppercase;
  }

  /* Progress track */
  .ls-bar-wrap {
    width: 100%;
    height: 4px;
    background: rgba(58,210,159,0.06);
    border: 1px solid rgba(58,210,159,0.08);
    border-radius: 8px;
    overflow: hidden;
    padding: 1px;
  }
  .ls-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #165b40, #3ad29f, #7fffda);
    border-radius: 4px;
    transition: width 0.3s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 0 12px rgba(58,210,159,0.85);
  }

  /* Diagnostic Console */
  .ls-console {
    display: flex;
    gap: 0.4rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.65rem;
    color: #3ad29f;
    background: rgba(58,210,159,0.03);
    border: 1px solid rgba(58,210,159,0.06);
    padding: 0.4rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }
  .ls-console-prompt {
    color: rgba(58,210,159,0.4);
    user-select: none;
    animation: lsFlicker 1.2s steps(2, start) infinite;
  }
  .ls-status {
    text-transform: uppercase;
    color: rgba(58,210,159,0.85);
  }

  @keyframes lsFlicker {
    to { visibility: hidden; }
  }
</style>

<!-- Inline SVG gradient defs (must be in DOM for stroke:url() to work) -->
<svg width="0" height="0" style="position:absolute">
  <defs>
    <linearGradient id="lsGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#3ad29f"/>
      <stop offset="100%" stop-color="#7fffda"/>
    </linearGradient>
  </defs>
</svg>

<script>
  (function() {
    const screen = document.getElementById('loadingScreen') as HTMLElement | null;
    const bar    = document.getElementById('lsBar')       as HTMLElement | null;
    const status = document.getElementById('lsStatus')    as HTMLElement | null;
    const hudPct = document.getElementById('lsHudPct')    as HTMLElement | null;
    const canvas = document.getElementById('lsCanvas')    as HTMLCanvasElement | null;
 
    if (!screen) return;
 
    // ── Interactive Glowing Neural Grid ──────────────────────────────
    if (canvas) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        const resize = () => { canvas.width = innerWidth; canvas.height = innerHeight; };
        resize();
        window.addEventListener('resize', resize, { passive: true });
 
        const spacing = 65;
        const cols = Math.ceil(innerWidth / spacing) + 1;
        const rows = Math.ceil(innerHeight / spacing) + 1;
        const dots: { x: number; y: number; originX: number; originY: number; vx: number; vy: number; phase: number; speed: number }[] = [];
 
        for (let c = 0; c < cols; c++) {
          for (let r = 0; r < rows; r++) {
            const x = c * spacing + (Math.random() - 0.5) * 30;
            const y = r * spacing + (Math.random() - 0.5) * 30;
            dots.push({
              x,
              y,
              originX: x,
              originY: y,
              vx: (Math.random() - 0.5) * 8,
              vy: (Math.random() - 0.5) * 8,
              phase: Math.random() * Math.PI * 2,
              speed: 0.4 + Math.random() * 0.8
            });
          }
        }
 
        let raf: number;
        const draw = () => {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          const time = performance.now() / 1000;
 
          // Update & draw nodes
          dots.forEach(d => {
            // Subtle drift
            d.x = d.originX + Math.sin(time * d.speed + d.phase) * 15;
            d.y = d.originY + Math.cos(time * d.speed + d.phase) * 15;
 
            const pulse = Math.sin(time * 2 + d.phase) * 0.5 + 0.5;
            ctx.beginPath();
            ctx.arc(d.x, d.y, 1.5 + pulse * 1, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(58, 210, 159, ${0.12 + pulse * 0.15})`;
            ctx.fill();
          });
 
          // Draw connection links between nearby nodes
          const maxDist = 85;
          for (let i = 0; i < dots.length; i++) {
            for (let j = i + 1; j < dots.length; j++) {
              const dx = dots[i].x - dots[j].x;
              const dy = dots[i].y - dots[j].y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < maxDist) {
                const alpha = (1 - dist / maxDist) * 0.12;
                ctx.beginPath();
                ctx.moveTo(dots[i].x, dots[i].y);
                ctx.lineTo(dots[j].x, dots[j].y);
                ctx.strokeStyle = `rgba(58, 210, 159, ${alpha})`;
                ctx.lineWidth = 0.8;
                ctx.stroke();
              }
            }
          }
          raf = requestAnimationFrame(draw);
        };
        draw();
 
        screen.addEventListener('transitionend', () => {
          if (screen.classList.contains('hidden')) cancelAnimationFrame(raf);
        }, { once: true });
      }
    }
 
    // ── Progress + HUD Sync ───────────────────────────
    const steps = [
      { pct: 12, msg: 'RETRIEVING SOURCE MODULES...' },
      { pct: 38, msg: 'RESOLVING INTEGRITY PACKS...' },
      { pct: 64, msg: 'INJECTING RENDERING SCHEMAS...' },
      { pct: 88, msg: 'ESTABLISHING SECURE CONNECTION...' },
      { pct: 100, msg: 'WORKSPACE READY.' },
    ];
    let step = 0;
    const tick = setInterval(() => {
      if (step >= steps.length) { clearInterval(tick); return; }
      const current = steps[step];
      if (bar) bar.style.width = current.pct + '%';
      if (status) status.textContent = current.msg;
      if (hudPct) hudPct.textContent = String(current.pct).padStart(2, '0') + '%';
      step++;
    }, 380);
 
    function hide() {
      clearInterval(tick);
      if (bar) bar.style.width = '100%';
      if (status) status.textContent = 'SYSTEM LOADED.';
      if (hudPct) hudPct.textContent = '100%';
      setTimeout(() => {
        screen.classList.add('hidden');
        setTimeout(() => { screen.style.display = 'none'; }, 800);
      }, 300);
    }
 
    if (document.readyState === 'complete') { hide(); }
    else { window.addEventListener('load', hide); }
    setTimeout(hide, 4500);
  })();
</script>
