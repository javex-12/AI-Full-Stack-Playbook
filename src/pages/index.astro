<script>
  // Animate progress fills on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const fill = entry.target.querySelector('.progress-fill') as HTMLElement;
        if (fill) {
          const phase = fill.getAttribute('data-phase');
          // All modules complete for demo — set to 100%
          fill.style.width = '100%';
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.phase-progress').forEach(el => observer.observe(el));

  // Search trigger — dispatch custom event that CommandPalette listens for
  document.getElementById('searchTrigger')?.addEventListener('click', () => {
    // Try direct call first
    if (typeof (window as any).openPlaybookSearch === 'function') {
      (window as any).openPlaybookSearch();
    } else {
      // Fallback: dispatch event
      document.dispatchEvent(new CustomEvent('open-search'));
    }
  });
</script>
